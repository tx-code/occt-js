{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "occt-js Viewer",
  "version": "../../package.json",
  "identifier": "io.txcode.occtjs.viewer",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://127.0.0.1:4173",
    "beforeDevCommand": "npm run dev -- --host 127.0.0.1 --port 4173",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "occt-js Viewer",
        "width": 1440,
        "height": 900,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$RESOURCE/dist/*"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": {
      "../../dist/occt-js.js": "dist/occt-js.js",
      "../../dist/occt-js.wasm": "dist/occt-js.wasm"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
